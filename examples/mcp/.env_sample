# Exa search configuration
EXA_API_KEY=
EXA_API_URL=https://api.exa.ai/search
EXA_SEARCH_TYPE=auto
EXA_NUM_RESULTS=5
EXA_USER_LOCATION=US
EXA_MONTHLY_REQUEST_LIMIT=

# Tavily search configuration
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_MONTHLY_REQUEST_LIMIT=

# Brave Search API configuration
BRAVE_API_KEY=
BRAVE_API_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_COUNTRY=US
BRAVE_SEARCH_LANG=en
BRAVE_UI_LANG=en-US
BRAVE_SAFESEARCH=moderate
BRAVE_MONTHLY_REQUEST_LIMIT=

# Unified search provider routing
SEARCH_PROVIDER_ORDER=exa,tavily,brave
SEARCH_USAGE_FILE=.search_provider_usage.json

# Local vision LLM configuration
# Expected to be an OpenAI-compatible chat/completions endpoint.
LOCAL_VISION_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_VISION_ENDPOINT=/chat/completions
LOCAL_VISION_API_KEY=test
LOCAL_VISION_MODEL=your_local_vision_model_here
LOCAL_VISION_TIMEOUT_SECONDS=120
LOCAL_VISION_FETCH_REMOTE=true
LOCAL_VISION_SYSTEM_PROMPT=You are a precise vision assistant. Answer only from visible evidence in the image.

# MCP server configuration
MCP_HOST=0.0.0.0
MCP_PORT=18011
MCP_PATH=/mcp
